{
  "name": "audx-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser build of audx — TypeScript port of the pattern DSL + synth, validated against Python golden vectors.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/studio.ts --bundle --format=esm --minify --target=es2020 --outfile=../site/studio.js",
    "fixtures": "python ../scripts/gen_web_fixtures.py"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
